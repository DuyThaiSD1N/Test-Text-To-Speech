# =============================================================================
#  Voice Agent Configuration
# =============================================================================

# =============================================================================
# OPENAI API (BẮT BUỘC)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
AGENT_MODEL=gpt-4o-mini

# =============================================================================
# REDIS - CONVERSATION STORAGE (TÙY CHỌN)
# Nếu không cấu hình, conversation chỉ lưu trong memory (mất khi restart)
# =============================================================================
USE_REDIS=false
REDIS_URL=redis://localhost:6379
# Hoặc với password: redis://:password@localhost:6379
# Hoặc Redis Cloud: redis://username:password@host:port

# =============================================================================
# TTS - TEXT TO SPEECH (TÙY CHỌN)
# Nếu không cấu hình, agent vẫn hoạt động nhưng không có âm thanh
# =============================================================================
TTS_WS_URL=ws://103.253.20.27:8767
TTS_API_KEY=your-tts-api-key
TTS_VOICE=thuyanh-north

# Các voice khác có thể dùng:
# TTS_VOICE=thanhha-north
# TTS_VOICE=minhquan-south

# =============================================================================
# ASR - AUTOMATIC SPEECH RECOGNITION (TÙY CHỌN)
# Nếu không cấu hình, vẫn có thể chat bằng text
# =============================================================================
ASR_GRPC_URI=103.253.20.28:9000
ASR_TOKEN=your-asr-token

# Cấu hình âm thanh
ASR_CHANNELS=1
ASR_RATE=8000
ASR_FORMAT=S16LE

# Cấu hình nhận dạng
ASR_SINGLE_SENTENCE=False
ASR_SILENCE_TIMEOUT=10
ASR_SPEECH_TIMEOUT=1
ASR_SPEECH_MAX=30

# =============================================================================
# SERVER PORT
# =============================================================================
AGENT_SERVER_PORT=8002

# =============================================================================
# LLM TRACING (TÙY CHỌN)
# Lưu lịch sử LLM calls vào file JSON để debug và phân tích
# =============================================================================
ENABLE_LLM_TRACING=true
LLM_TRACE_FILE=logs/llm_traces.jsonl

# =============================================================================
# LANGSMITH TRACING (TÙY CHỌN)
# Theo dõi và debug LLM reasoning trên LangSmith dashboard
# Đăng ký tại: https://smith.langchain.com/
# =============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=voice-chatbot-insurance

# =============================================================================
# SPEED OPTIMIZATION
# =============================================================================
# Dùng prompt ngắn để tăng tốc độ (true) hoặc prompt đầy đủ cho độ chính xác (false)
USE_FAST_PROMPT=true

# Giới hạn số lượng messages trong conversation history (giảm tokens)
MAX_HISTORY_MESSAGES=10
